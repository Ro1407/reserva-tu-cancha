// Whenever there is a change in the schema, run the following commands to update the database and generate the Prisma client:
// pnpx prisma generate
// prisma migrate dev --create-only                (for comparing the sql files before applying)
// pnpx prisma migrate dev --name <migration_name>
// pnpx prisma migrate deploy

// In case you want to use Prisma Studio to visualize and manage your database, you can run: pnpx prisma studio

generator client {
  provider = "prisma-client"
  output   = "../prisma/generated"
}

datasource db {
  provider = "postgresql"
}

model Club {
  id          String   @id @default(uuid())
  name        String   @unique
  description String
  phone       String
  location    String
  address     String
  rating      Int      @default(0) // float * 10
  image       String?
  sports      Sport[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  courts Court[]

  @@map("club") // Map to "club" table in the database
}

enum Sport {
  Futbol
  Tennis
  Paddle
  Basketball
  Volleyball
  Hockey
}

model Court {
  id          String     @id @default(uuid())
  name        String
  address     String
  sport       Sport
  description String
  rating      Int        @default(0) // float * 10
  price       Int // Price per slot in cents
  amenities   Amenitie[]
  image       String?
  state       CourtState @default(Activa)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  // Foreign Keys
  clubId String

  // Relations
  club         Club          @relation(fields: [clubId], references: [id], onDelete: Cascade)
  reservations Reservation[]
  timeSlots    TimeSlot[]

  @@unique([clubId, name]) // Unique name per club
  @@map("court")
}

// Represents if the court can be reserved or not (e.g. due to maintenance for several days)
enum CourtState {
  Activa
  Inactiva
}

enum Amenitie {
  Indoor
  Outdoor
  Iluminacion
  Vestuarios
  Estacionamiento
  AireAcondicionado
  Calefaccion
  CespedSintetico
  Buffet
}

model Reservation {
  id        String           @id @default(uuid())
  date      String // Date in YYYY-MM-DD format
  timeSlot  TimeSlot
  price     Int // Price in cents
  state     ReservationState @default(Pendiente)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  // Foreign Keys
  courtId String
  userId  String

  // Relations
  court Court @relation(fields: [courtId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("reservation")
}

enum ReservationState {
  Confirmada
  Pendiente
  Cancelada
  Mantenimiento
}

enum TimeSlot {
  H0800
  H0900
  H1000
  H1100
  H1200
  H1300
  H1400
  H1500
  H1600
  H1700
  H1800
  H1900
  H2000
  H2100
}

model User {
  id       String  @id @default(uuid())
  password String?
  email    String  @unique
  name     String
  phone    String?
  role     Role    @default(USER)

  reservations Reservation[]

  @@map("user")
}

enum Role {
  USER
  ADMIN
}

model PushSubscription {
  id             String @id @default(uuid())
  endpoint       String
  expirationTime Float?
  p256dh         String
  auth           String
  subscriber     String @default("")

  @@map("push_subscription")
}
