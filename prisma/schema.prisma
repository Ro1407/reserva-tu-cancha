// Whenever there is a change in the schema, run the following commands to update the database and generate the Prisma client:
// pnpx prisma generate
// pnpx prisma migrate dev --name <migration_name>
// pnpx prisma migrate deploy

// In case you want to use Prisma Studio to visualize and manage your database, you can run: pnpx prisma studio

generator client {
  provider = "prisma-client-js"
}

generator zod {
  provider = "zod-prisma"
  output   = "./zod" // (default) the directory where generated zod schemas will be saved

  // relationModel = true // (default) Create and export both plain and related models.
  // relationModel         = "default" // Do not export model without relations.
  relationModel = false // Do not generate related model

  modelCase = "PascalCase" // (default) Output models using pascal case (ex. UserModel, PostModel)
  // modelCase             = "camelCase" // Output models using camel case (ex. userModel, postModel)

  modelSuffix = "Schema" // (default) Suffix to apply to your prisma models when naming Zod schemas

  // useDecimalJs          = false // (default) represent the prisma Decimal type using as a JS number
  useDecimalJs = true // represent the prisma Decimal type using Decimal.js (as Prisma does)

  imports = "" // (default) will import the referenced file in generated schemas to be used via imports.someExportedVariable

  // https://www.prisma.io/docs/concepts/components/prisma-client/working-with-fields/working-with-json-fields#filtering-by-null-values
  //  prismaJsonNullability = true // (default) uses prisma's scheme for JSON field nullability
  // prismaJsonNullability = false // allows null assignment to optional JSON fields
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Club {
  id          String   @id @default(uuid())
  /// @zod.min(1, 'Por favor, proporcione un nombre único para el club' )
  name        String   @unique
  /// @zod.min(1, 'Por favor, proporcione una descripción del club' )
  description String
  /// @zod.min(1, 'Por favor, proporcione un número de teléfono del club' )
  /// @zod.regex(/^\+[1-9]\d{1,3}\s\d{1,4}\s\d{3}-\d{4}$/, 'Por favor, proporcione un número de teléfono válido en formato +CódigoPais CódigoÁrea XXX-XXXX' )
  phone       String
  /// @zod.min(1, 'Por favor, proporcione la ubicación del club' )
  location    String
  /// @zod.min(1, 'Por favor, proporcione la dirección del club' )
  address     String
  /// @zod.max(50, 'El rating del club debe estar entre 0.0 y 5.0' )
  rating      Int      @default(0) // float * 10
  image       String?
  sports      Sport[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  courts Court[]

  @@map("club") // Map to "club" table in the database
}

enum Sport {
  Futbol
  Tennis
  Paddle
  Basketball
  Volleyball
  Hockey
}

model Court {
  id          String     @id @default(uuid())
  /// @zod.min(1, 'Por favor, proporcione un nombre único para la cancha' )
  name        String
  /// @zod.min(1, 'Por favor, proporcione una dirección para la cancha' )
  address     String
  sport       Sport
  /// @zod.min(1, 'Por favor, proporcione una descripción de la cancha' )
  description String
  /// @zod.max(50, 'El rating de la cancha debe estar entre 0.0 y 5.0' )
  rating      Int        @default(0) // float * 10
  /// @zod.min(1, 'Por favor, proporcione un precio por hora de la cancha' )
  price       Int // Price per slot in cents
  amenities   Amenitie[]
  image       String?
  state       CourtState @default(Activa)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  // Foreign Keys
  /// @zod.min(1, 'Por favor, proporcione el club al que pertenece la cancha' )
  clubId String

  // Relations
  club         Club          @relation(fields: [clubId], references: [id], onDelete: Cascade)
  reservations Reservation[]
  timeSlots    TimeSlot[]

  @@unique([clubId, name]) // Unique name per club
  @@map("court")
}

// Represents if the court can be reserved or not (e.g. due to maintenance for several days)
enum CourtState {
  Activa
  Inactiva
}

enum Amenitie {
  Indoor
  Outdoor
  Iluminacion
  Vestuarios
  Estacionamiento
  AireAcondicionado
  Calefaccion
  CespedSintetico
  Buffet
}

model Reservation {
  id        String           @id @default(uuid())
  /// @zod.min(1, 'Por favor, proporcione una fecha para la reserva' )
  /// @zod.date('Por favor, proporcione una fecha válida' )
  date      String // Date in YYYY-MM-DD format
  timeSlot  TimeSlot
  /// @zod.min(1, 'Por favor, proporcione un precio para la reserva' )
  price     Int // Price in cents
  state     ReservationState @default(Pendiente)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  // Foreign Keys
  /// @zod.min(1, 'Por favor, proporcione la cancha para la reserva' )
  courtId String
  /// @zod.min(1, 'Por favor, proporcione el usuario que realiza la reserva' )
  userId  String

  // Relations
  court Court @relation(fields: [courtId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("reservation")
}

enum ReservationState {
  Confirmada
  Pendiente
  Cancelada
  Mantenimiento
}

enum TimeSlot {
  H0800
  H0900
  H1000
  H1100
  H1200
  H1300
  H1400
  H1500
  H1600
  H1700
  H1800
  H1900
  H2000
  H2100
}

model User {
  id       String  @id @default(uuid())
  /// @zod.min(1, 'Por favor, proporcione una contraseña' )
  password String?
  /// @zod.min(1, 'Por favor, proporcione un correo electrónico único' )
  /// @zod.email('Por favor, proporcione un correo electrónico válido' )
  email    String  @unique
  /// @zod.min(1, 'Por favor, proporcione un nombre de usuario' )
  name     String
  /// @zod.regex(/^\+[1-9]\d{1,3}\s\d{1,4}\s\d{3}-\d{4}$/, 'Por favor, proporcione un número de teléfono válido en formato +CódigoPais CódigoÁrea XXX-XXXX' )
  phone    String?
  role     Role    @default(USER)

  reservations Reservation[]

  @@map("user")
}

enum Role {
  USER
  ADMIN
}
